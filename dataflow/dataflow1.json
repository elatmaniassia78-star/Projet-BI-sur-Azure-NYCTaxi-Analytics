{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "raw",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "curated",
						"type": "DatasetReference"
					},
					"name": "sink"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "cast1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          VendorID as integer,",
				"          tpep_pickup_datetime as string,",
				"          tpep_dropoff_datetime as string,",
				"          passenger_count as long,",
				"          trip_distance as double,",
				"          RatecodeID as long,",
				"          store_and_fwd_flag as string,",
				"          PULocationID as integer,",
				"          DOLocationID as integer,",
				"          payment_type as long,",
				"          fare_amount as double,",
				"          extra as double,",
				"          mta_tax as double,",
				"          tip_amount as double,",
				"          tolls_amount as double,",
				"          improvement_surcharge as double,",
				"          total_amount as double,",
				"          congestion_surcharge as double,",
				"          Airport_fee as double,",
				"          cbd_congestion_fee as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> source1",
				"source1 select(mapColumn(",
				"          VendorID,",
				"          tpep_pickup_datetime,",
				"          tpep_dropoff_datetime,",
				"          passenger_count,",
				"          trip_distance,",
				"          RatecodeID,",
				"          PULocationID,",
				"          DOLocationID,",
				"          payment_type,",
				"          fare_amount,",
				"          extra,",
				"          mta_tax,",
				"          tip_amount,",
				"          tolls_amount,",
				"          improvement_surcharge,",
				"          total_amount,",
				"          congestion_surcharge,",
				"          Airport_fee,",
				"          cbd_congestion_fee",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 cast(output(",
				"          tpep_pickup_datetime as timestamp 'yyyy-MM-dd\\'T\\'HH:mm:ss',",
				"          tpep_dropoff_datetime as timestamp 'yyyy-MM-dd\\'T\\'HH:mm:ss',",
				"          passenger_count as integer,",
				"          RatecodeID as integer",
				"     ),",
				"     errors: true) ~> cast1",
				"cast1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink"
			]
		}
	}
}